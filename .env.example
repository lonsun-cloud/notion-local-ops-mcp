# ──────────────────────────────────────────────────────────────
# notion-local-ops-mcp  —  Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values for your setup.
#   cp .env.example .env
#
# All variables are optional; defaults are shown after the "=".
# ──────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
# Listen address. Use 0.0.0.0 to accept connections from LAN / tunnel.
NOTION_LOCAL_OPS_HOST=127.0.0.1
# Listen port.
NOTION_LOCAL_OPS_PORT=8766

# ── Workspace ─────────────────────────────────────────────────
# Default working directory for tool calls (absolute path).
# NOTION_LOCAL_OPS_WORKSPACE_ROOT=~
# Directory for runtime state (tasks, oauth.json, etc.).
# NOTION_LOCAL_OPS_STATE_DIR=~/.notion-local-ops-mcp

# ── Authentication ────────────────────────────────────────────
# Shared bearer token. Clients must send  Authorization: Bearer <token>.
# Leave empty to disable auth (NOT recommended for public exposure).
NOTION_LOCAL_OPS_AUTH_TOKEN=
# Auth mode: "shared_token" | "oauth" | "none".  Auto-detected if empty.
# NOTION_LOCAL_OPS_AUTH_MODE=
# Public base URL for OAuth issuer metadata (e.g. https://mcp.example.com).
# NOTION_LOCAL_OPS_PUBLIC_BASE_URL=
# Separate token for the OAuth login form (defaults to AUTH_TOKEN).
# NOTION_LOCAL_OPS_OAUTH_LOGIN_TOKEN=
# Space-separated OAuth scopes.
# NOTION_LOCAL_OPS_OAUTH_SCOPES=local-ops
# OAuth access-token TTL in seconds (default: 86400 = 24 h).
# NOTION_LOCAL_OPS_OAUTH_TOKEN_TTL_SECONDS=86400

# ── IP Whitelist ──────────────────────────────────────────────
# Comma-separated CIDRs / IPs allowed to connect.
# Leave empty to disable IP filtering (all IPs allowed, auth still required).
# Example: 127.0.0.1,::1,192.168.0.0/16,10.0.0.0/8,131.149.232.0/21
NOTION_LOCAL_OPS_ALLOWED_IPS=
# URL to fetch a dynamic IP list (JSON with "prefixes" or plain-text CIDRs).
# ChatGPT connector IPs: https://openai.com/chatgpt-connectors.json
NOTION_LOCAL_OPS_ALLOWED_IPS_URL=
# How often (seconds) to refresh the remote IP list. Default: 14400 (4 hours).
# NOTION_LOCAL_OPS_ALLOWED_IPS_REFRESH_SECONDS=14400

# ── Executors ─────────────────────────────────────────────────
# Shell command to invoke codex / claude-code for delegate_task.
# NOTION_LOCAL_OPS_CODEX_COMMAND=codex
# NOTION_LOCAL_OPS_CLAUDE_COMMAND=claude
# Timeout (seconds) for run_command.
# NOTION_LOCAL_OPS_COMMAND_TIMEOUT=120
# Timeout (seconds) for delegate_task.
# NOTION_LOCAL_OPS_DELEGATE_TIMEOUT=1800

# ── Misc ──────────────────────────────────────────────────────
# Set to 1 to enable verbose MCP request/response logging to stderr.
# NOTION_LOCAL_OPS_DEBUG_MCP_LOGGING=0
# Graceful shutdown wait in seconds.
# NOTION_LOCAL_OPS_GRACEFUL_SHUTDOWN_SECONDS=30
